# Copy this file to .env and fill in real values. Never commit .env.

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Secret key used to authenticate requests to the /chat API endpoint.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-secret-api-key-here

# --- LangSmith tracing (optional but strongly recommended in production) ---
# Sign up free at https://smith.langchain.com, create a project, copy your API key.
# When enabled, every chain step (retrieval, LLM call, re-ranking) is traced.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=skyline-rag-chatbot
